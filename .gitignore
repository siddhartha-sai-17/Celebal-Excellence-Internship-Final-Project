# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
venv/
.venv/
env/
ENV/

# Streamlit local state
.streamlit/runtime/
.streamlit/secret.toml

# Pytest cache
.pytest_cache/
.coverage
htmlcov/

# Heavy Machine Learning Assets — raw dataset (too large for GitHub)
dataset/
fashion-dataset/
images/

# Exclude raw data but allow subset images and metadata CSV
!data/subset/images/
!data/subset/images/*.jpg
data/raw/

# Model weights (large binary files)
models/weights/
*.h5
*.keras
*.onnx
*.pkl
*.pb

# Specifically unignore model checkpoint files so they are uploaded to GitHub
!models/checkpoints/
!models/checkpoints/**/*.keras
!models/checkpoints/**/*.json
!models/checkpoints/**/*.npy



# Logs & temporary files
logs/*.log
logs/
.ipynb_checkpoints/
tmp/
temp/

# OS specific files
.DS_Store
Thumbs.db
